# Config de respaldo/actualización (copiar a .env.backup y completar).
# Lo leen scripts/backup_to_wasabi.sh y scripts/daily_update.sh.

# ── Wasabi (S3-compatible) ───────────────────────────────────────────────────
# Nombre del remote rclone (ver scripts/README.md para crearlo) y el bucket.
RCLONE_REMOTE=wasabi
WASABI_BUCKET=leyes-co

# ── Almacenes ────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=legal_corpus
QDRANT_URL=http://localhost:6333
NEO4J_USER=neo4j
NEO4J_PASSWORD=password          # ¡cámbialo en prod!

# ── Retención de backups fechados ────────────────────────────────────────────
RETAIN_DAILY=7

# ── Ciclo diario ─────────────────────────────────────────────────────────────
# Fuentes a refrescar a diario (las de mayor cambio). El resto se corre a mano.
DAILY_SOURCES="corte_constitucional csj consejo_estado dian creg crc cra jep"
SOCRATA_DATASETS="legislacion cc_sentencias tratados"
SCRAPE_RPS=3
SCRAPE_WORKERS=5

# COMPOSE="docker compose -f docker-compose.yml -f docker-compose.prod.yml"
