# Configuración del backend de embeddings.
# Copia este archivo a .env (gitignored) y ajústalo. docker-compose lo inyecta a
# los servicios api, pipeline y mcp.
#
# CRÍTICO: el MISMO backend/modelo/dim debe usarse al INDEXAR (export vector) y al
# CONSULTAR (search/verify/api/mcp). Si difieren, Qdrant responde
# "Vector dimension error: expected dim: X, got Y" y la búsqueda falla.
# Si cambias de modelo, recrea la colección: `export vector --recreate`.

# ── Backend ───────────────────────────────────────────────────────────────────
# fastembed = local en CPU (jina-es 768d, default, sin GPU).
# openai    = endpoint OpenAI-compatible (LM Studio / vLLM / TEI), p.ej. tu GPU.
EMBEDDING_BACKEND=openai

# ── Endpoint OpenAI-compatible (solo si EMBEDDING_BACKEND=openai) ─────────────
# La URL debe terminar en /v1. Desde la VM, apunta a tu GPU vía Tailscale, p.ej.
# http://100.x.y.z:1234/v1 (LM Studio) o http://100.x.y.z:8001/v1 (vLLM/TEI).
EMBEDDING_API_URL=http://100.x.y.z:1234/v1
EMBEDDING_API_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_API_KEY=EMPTY

# Dimensión de salida. 0 = nativa del modelo. Para Qwen3-Embedding, 1536 usa
# truncación Matryoshka (vectores más livianos, calidad casi nativa).
# DEBE coincidir con la dimensión con la que se creó la colección.
EMBEDDING_DIM=1536
